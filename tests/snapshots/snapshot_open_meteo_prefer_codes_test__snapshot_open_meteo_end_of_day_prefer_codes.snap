            <path d="M 0 0 L 10 10 M 10 0 L 0 10" stroke="blue" stroke-width="1" />
        </pattern>
        <!-- Rain patterns based on precipitation intensity -->
        <!-- patternTransform flips the tile back upright because blocks are drawn inside
